{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "SimpleC",
  "scopeName": "source.simplec",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#types"
    },
    {
      "include": "#booleans"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#functions"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.simplec",
          "match": "##.*$"
        },
        {
          "name": "comment.block.simplec",
          "begin": "#-",
          "end": "-#"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.simplec",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.simplec",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.simplec",
          "match": "\\b(if|elif|else|while|for|fun|return|try|catch|print)\\b"
        },
        {
          "name": "keyword.operator.logical.simplec",
          "match": "\\b(and|or|xor|not)\\b"
        },
        {
          "name": "keyword.operator.simplec",
          "match": "\\.\\.\\.|==|!=|>=|<=|>|<|\\+|-|\\*|/|%|\\^|="
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "storage.type.simplec",
          "match": "\\b(int|bool|double|float|char|void)\\b"
        }
      ]
    },
    "booleans": {
      "patterns": [
        {
          "name": "constant.language.boolean.simplec",
          "match": "\\b(true|false|True|False)\\b"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.simplec",
          "match": "\\b\\d+(?:\\.\\d+)?\\b"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "entity.name.function.simplec",
          "match": "\\b([A-Za-z_][A-Za-z0-9_]*)\\s*(?=\\()"
        }
      ]
    }
  }
}
